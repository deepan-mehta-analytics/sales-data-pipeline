# =============================================================================
# .gitignore
# Files and directories that should NOT be committed to the git repository.
# Comments must be on their own line — NOT at the end of pattern lines.
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode and distribution artefacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Testing and coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# -----------------------------------------------------------------------------
# Log files
# -----------------------------------------------------------------------------
*.log
logs/*.log

# -----------------------------------------------------------------------------
# Pipeline data outputs
# Silver and gold Parquet files are regenerated on every pipeline run.
# The bronze CSV should be downloaded from Kaggle and placed manually.
# -----------------------------------------------------------------------------
data/silver/*.parquet
data/gold/*.parquet
database/*.duckdb

# Keep directory structure by preserving .gitkeep placeholders
!data/silver/.gitkeep
!data/gold/.gitkeep
!database/.gitkeep
!logs/.gitkeep

# -----------------------------------------------------------------------------
# Jupyter notebooks — strip outputs and checkpoints
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Environment and secrets — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
secrets.yaml
*.key
*.pem

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.tar
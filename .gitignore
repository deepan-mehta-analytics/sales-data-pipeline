# =============================================================================
# .gitignore
# Files and directories that should NOT be committed to the git repository.
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/           # Compiled Python bytecode cache directories
*.py[cod]              # Compiled bytecode files (.pyc, .pyo, .pyd)
*.pyo
*.pyd
*.egg-info/            # Package metadata generated by setuptools
*.egg
dist/                  # Built distribution artefacts
build/                 # Build output directory
.eggs/                 # Eggs directory (legacy Python package format)

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/                 # Standard virtual environment directory
venv/                  # Alternative virtual environment name
env/                   # Another common virtual environment name
ENV/

# ---------------------------------------------------------------------------
# Testing and coverage
# ---------------------------------------------------------------------------
.pytest_cache/         # pytest discovery and session cache
.coverage              # Raw coverage data file produced by coverage.py
coverage.xml           # XML coverage report (uploaded as CI artefact)
htmlcov/               # HTML coverage report directory
*.log                  # Log files (pipeline.log is regenerated on each run)

# ---------------------------------------------------------------------------
# Pipeline data outputs
# Do NOT commit generated data files. The bronze CSV should be downloaded
# from Kaggle and placed manually; silver/gold Parquets are pipeline outputs.
# ---------------------------------------------------------------------------
data/silver/*.parquet  # Cleaned silver-layer Parquet files
data/gold/*.parquet    # Gold-layer aggregation Parquet files
database/*.duckdb      # DuckDB analytical database file

# Keep the directory structure tracked by preserving .gitkeep files
!data/silver/.gitkeep
!data/gold/.gitkeep
!database/.gitkeep
!logs/.gitkeep

# ---------------------------------------------------------------------------
# Jupyter notebooks
# Strip outputs and checkpoints from notebooks before committing.
# Notebook outputs (plots, tables) should not be stored in git.
# ---------------------------------------------------------------------------
.ipynb_checkpoints/    # Jupyter auto-save checkpoint directory
notebooks/.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/               # VS Code workspace settings (team members may differ)
.idea/                 # JetBrains IDE project files (PyCharm, DataSpell)
*.swp                  # Vim swap files
*.swo                  # Vim swap files (overflow)
.DS_Store              # macOS Finder metadata files
Thumbs.db              # Windows thumbnail cache files

# ---------------------------------------------------------------------------
# Environment and secrets
# ---------------------------------------------------------------------------
.env                   # Local environment variable overrides (API keys, etc.)
.env.local
.env.*.local
secrets.yaml           # Never commit secrets or credentials to git

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.tar                  # Docker image archives exported with 'docker save'
